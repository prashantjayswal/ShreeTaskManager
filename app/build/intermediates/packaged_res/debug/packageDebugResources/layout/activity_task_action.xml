<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvActionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task Starting"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTaskTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Task Name"
        android:textColor="@color/accentColor"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvActionTitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartTask"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="48dp"
        android:text="Start Task"
        app:backgroundTint="@color/card_green"
        app:cornerRadius="16dp"
        android:textColor="@color/primaryDarkColor"
        app:layout_constraintTop_toBottomOf="@id/tvTaskTitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReschedule"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="Reschedule"
        app:backgroundTint="@color/card_purple"
        app:cornerRadius="16dp"
        android:textColor="@color/primaryDarkColor"
        app:layout_constraintTop_toBottomOf="@id/btnStartTask" />

</androidx.constraintlayout.widget.ConstraintLayout>